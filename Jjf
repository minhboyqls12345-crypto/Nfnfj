(function() {
    'use strict';

    function unlockButton() {
        const targetButton = document.getElementById('invisibleCaptchaShortlink');

        if (targetButton && targetButton.hasAttribute('disabled')) {

            targetButton.removeAttribute('disabled');

            console.log('✅ Đã bỏ disabled nút');
        }
    }

    window.addEventListener('load', unlockButton);

    const observer = new MutationObserver(unlockButton);
    observer.observe(document.body, {
        childList: true, 
        subtree: true    
    });
})();
